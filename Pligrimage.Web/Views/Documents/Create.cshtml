@model Pligrimage.Entities.Document

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Document</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="FileName" class="control-label"></label>
                <input asp-for="FileName" class="form-control" />
                <span asp-validation-for="FileName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ContentType" class="control-label"></label>
                <input asp-for="ContentType" class="form-control" />
                <span asp-validation-for="ContentType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Path" class="control-label"></label>
                <input asp-for="Path" class="form-control" />
                <span asp-validation-for="Path" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DocumnetType" class="control-label"></label>
                <input asp-for="DocumnetType" class="form-control" />
                <span asp-validation-for="DocumnetType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Year" class="control-label"></label>
                <input asp-for="Year" class="form-control" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>


            <div class="form-group">
                <label asp-for="VisitDate" class="control-label"></label>
                <input asp-for="VisitDate" id="visitDate" class="form-control"
                       onblur="formatDate(this)" placeholder="dd/mm/yyyy" autocomplete="off" />
                <span asp-validation-for="VisitDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

}

    @functions {
    public string FormatVisitDate(DateTime? date)
    {
        if (!date.HasValue) return "";
        return date.Value.ToString("dd/MM/yyyy hh:mm tt")
            .Replace("AM", "Morning")
            .Replace("PM", "Evening");
    }
}
<script>
    function formatDate(input) {
        if (!input.value) return;

        let date = new Date(input.value);
        if (isNaN(date.getTime())) return; // Avoid invalid date errors

        let hours = date.getHours();
        let minutes = date.getMinutes().toString().padStart(2, "0");
        let suffix = hours < 12 ? "Morning" : "Evening";

        hours = hours % 12 || 12; // Convert to 12-hour format

        let formattedDate = date.getDate().toString().padStart(2, "0") + "/" +
                            (date.getMonth() + 1).toString().padStart(2, "0") + "/" +
                            date.getFullYear() + " " +
                            hours + ":" + minutes + " " + suffix;

        input.value = formattedDate;
    }

    document.addEventListener("DOMContentLoaded", function () {
        let visitDateInput = document.getElementById("visitDate");
        if (visitDateInput) {
            formatDate(visitDateInput);
        }
    });
</script>



