@inject Pligrimage.Services.Interface.IAdminService _userService
@using System.Security.Claims;

<html dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hajj.Web</title>

    <!-- Core styles -->
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/lib/bootstrap-rtl/css/bootstrap-rtl.css" rel="stylesheet" />
    <link href="~/lib/bootstrap/dist/css/rtl/bootstrap.css" rel="stylesheet" />
    <link href="~/lib/hc-offcanvas/hc-offcanvas-nav.css" rel="stylesheet" />
    <link href="~/lib/font-awesome-4.7.0/css/font-awesome.css" rel="stylesheet" />
    <link href="~/lib/mdbootsrap/css/mdb.css" rel="stylesheet" />

    <!-- DataTables with Bootstrap 4 styling -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap4.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap4.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap4.min.css" />

    <!-- Toastr notifications -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <!-- Select2 for searchable / multi-select dropdowns -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />

    <!-- Flatpickr date pickers -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />

    <style>
        /* DataTables RTL fixes */
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            direction: rtl;
            text-align: right;
        }
        .dataTables_wrapper .dataTables_filter input {
            margin-right: 0.5em;
            margin-left: 0;
        }
        table.dataTable thead th {
            background-color: #f8f9fa;
            color: #212529;
            font-weight: bold;
            border-color: #dde2e7;
        }
        table.dataTable tbody tr:hover {
            background-color: #f1f8ff;
        }
        .dt-buttons { margin-bottom: 10px; }
    </style>
</head>

<body>

    @{
        var identity = (ClaimsIdentity)User.Identity;
        IEnumerable<Claim> claims = identity.Claims;
        var permissionVm = await _userService.GetPermissionsByUser(identity.Name);
        var roles = permissionVm.GroupBy(x => x.RoleName);
    }

    <header>
        <nav class="navbar fixed-top navbar-expand-lg rgba-blue-grey-strong scrolling-navbar">
            <div class="navbar-brand"><a>&nbsp;</a></div>
            <div class="toggle"><span></span></div>

            <ul class="navbar-nav ml-auto nav-flex-icons">
                <li class="nav-item dropdown">
                    <a id="navbarMenuLink" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"></a>
                    <div class="dropdown-menu dropdown-menu-right dropdown-default" aria-labelledby="navbarMenuLink">
                        <a class="dropdown-item">User1</a>
                        <a class="dropdown-item">User2</a>
                    </div>
                </li>
            </ul>

            <ul class="nav navbar-nav navbar-right">
                <li>@await Html.PartialAsync("_LoginPartial")</li>
            </ul>

            <div style="float:left">
                <a href="@Url.Action("Index","Home")"><img src="~/Image/logo.png" style="width:40px" /></a>
            </div>
        </nav>

        <nav id="main-nav">
            <ul>
                @foreach (var role in roles)
                {
                    <li>
                        <span>@role.Key</span>
                        <ul>
                            @foreach (var item in permissionVm.Where(x => x.RoleName == @role.Key))
                            {
                                <li>
                                    <a asp-area="" asp-controller=@item.ControllerName asp-action=@item.ActionName>
                                        @item.Description
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }
            </ul>
        </nav>
    </header>

    <div class="container-fluid" id="slide" style="margin-top: 80px">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer heavy-rain-gradient text-center">
        <div class="container">
            &copy; 2019 - نظام إدارة بعثة الحج العسكرية -
            <a asp-area="" asp-controller="Home" asp-action="Privacy"></a>
        </div>
    </footer>

    <!-- Core scripts (jQuery first) -->
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap-rtl/js/bootstrap.bundle.js"></script>
    <script src="~/lib/bootstrap-rtl/js/bootstrap.js"></script>
    <script src="~/lib/hc-offcanvas/hc-offcanvas-nav.js"></script>
    <script src="~/lib/mdbootsrap/js/mdb.js"></script>
    <script src="~/lib/JsZip/jszip.js"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap4.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap4.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>

    <!-- Toastr -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <!-- Select2 -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- Flatpickr -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ar.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Global Toastr defaults (top-left RTL)
        toastr.options = {
            closeButton: true,
            progressBar: true,
            positionClass: "toast-top-left",
            timeOut: "4000",
            rtl: true
        };

        // Global DataTables defaults (Arabic + RTL)
        $.extend(true, $.fn.dataTable.defaults, {
            language: { url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/ar.json' },
            responsive: true,
            dom: '<"row"<"col-sm-6"B><"col-sm-6"f>>rt<"row"<"col-sm-6"i><"col-sm-6"p>>',
            buttons: [
                { extend: 'excel', text: '<i class="fa fa-file-excel-o"></i> Excel', className: 'btn btn-success btn-sm' },
                { extend: 'print', text: '<i class="fa fa-print"></i> طباعة', className: 'btn btn-info btn-sm' }
            ]
        });

        // Off-canvas RTL nav
        $('#main-nav').hcOffcanvasNav({
            maxWidth: false,
            navTitle: 'القائمة الرئيسية',
            customToggle: $('.toggle'),
            levelTitles: true,
            side: 'right',
            pushContent: '#slide',
            labelClose: 'إغلاق',
            labelBack: 'رجوع'
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>

</html>
