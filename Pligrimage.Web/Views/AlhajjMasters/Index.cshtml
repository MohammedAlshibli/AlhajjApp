@model IEnumerable<Pligrimage.Entities.AlhajjMaster>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CRUD DataTable</title>

    <!-- DataTables & Bootstrap CSS -->
    <link href="~/alhajjlab/jquery.datatables.min.css" rel="stylesheet" />
    <link href="~/alhajjlab/buttons.datatables.min.css" rel="stylesheet" />
    <link href="~/alhajjlab/bootstrap.min.css" rel="stylesheet" />
    <!-- Google Font for Better UI -->
    <link href="~/alhajjlab/css2.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fa;
            margin: 20px;
        }

        h4 {
            text-align: center;
            color: #333;
            font-weight: 600;
        }

        .dataTables_wrapper {
            margin-top: 20px;
        }

        table.dataTable thead {
            background-color: #007bff;
            color: white;
            text-align: center;
        }

        table.dataTable tbody tr:hover {
            background-color: #f1f1f1;
        }

        table {
            width: 100% !important;
            border-collapse: collapse;
        }

        .dt-buttons {
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <h4>CRUD DataTable</h4>
    <hr />

    <div class="container">
                        <a asp-action="Create" class="btn btn-outline-secondary py-1">
                            <i class="fa fa-pencil-alt" aria-hidden="true" title="Create"></i>

                        </a>
        <table id="tbl" class="display nowrap table table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th>الرقم العسكري</th>
                    <th>رقم المدني</th>
                    <th>الاسم بالكامل</th>
                    <th>تاريخ الميلاد</th>
                    <th>المحافظة</th>

                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.ServcieNumber)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.NIC)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.FullName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.DateOfBirth)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Region)
                        </td>
                        
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.PligrimageId">Edit</a> |
                            <a asp-action="Details" asp-route-id="@item.PligrimageId">Details</a> |
                            <a asp-action="Delete" asp-route-id="@item.PligrimageId">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Bootstrap Modal for Create/Edit -->
    <div class="modal fade" id="dataModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-body">
                    <input type="hidden" id="rowIndex">
                    <div class="mb-3">
                        <label>Name:</label>
                        <input type="text" id="name" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label>Age:</label>
                        <input type="number" id="age" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label>Email:</label>
                        <input type="email" id="email" class="form-control">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="saveData()">Save</button>
                </div>
            </div>
        </div>
    </div>

    <!-- jQuery & DataTables & Bootstrap -->
    <script src="~/alhajjlab/jquery-3.6.0.min.js"></script>
    <script src="~/alhajjlab/jquery.datatables.min.js"></script>
    <script src="~/alhajjlab/bootstrap.bundle.min.js"></script>

    <script>
        var table;

        $(document).ready(function () {
            table = $("#tbl").DataTable({
                dom: '<"dt-buttons"B>frtip',
                buttons: ['excelHtml5', 'csvHtml5', 'print'],
                responsive: true,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                pageLength: 10,
                pagingType: "full_numbers",
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Search records...",
                    lengthMenu: "Show _MENU_ entries"
                }
            });
        });

        function openModal(edit = false, rowIndex = null) {
            $("#modalTitle").text(edit ? "Edit Record" : "Add New Record");
            $("#name").val('');
            $("#age").val('');
            $("#email").val('');
            $("#rowIndex").val(rowIndex);
            $("#dataModal").modal("show");
        }

        function editRow(button) {
            var row = $(button).closest("tr");
            var data = table.row(row).data();
            $("#name").val(data[0]);
            $("#age").val(data[1]);
            $("#email").val(data[2]);
            $("#rowIndex").val(table.row(row).index());
            $("#modalTitle").text("Edit Record");
            $("#dataModal").modal("show");
        }

        function deleteRow(button) {
            var row = $(button).closest("tr");
            table.row(row).remove().draw();
        }

        function saveData() {
            var name = $("#name").val();
            var age = $("#age").val();
            var email = $("#email").val();
            var rowIndex = $("#rowIndex").val();

            if (name === "" || age === "" || email === "") {
                alert("All fields are required!");
                return;
            }

            if (rowIndex) {
                table.row(rowIndex).data([name, age, email, actionButtons()]).draw();
            } else {
                table.row.add([name, age, email, actionButtons()]).draw();
            }

            $("#dataModal").modal("hide");
        }

        function actionButtons() {
            return `<button class="btn btn-sm btn-warning" onclick="editRow(this)">Edit</button>
                    <button class="btn btn-sm btn-danger" onclick="deleteRow(this)">Delete</button>`;
        }
    </script>

</body>
</html>
