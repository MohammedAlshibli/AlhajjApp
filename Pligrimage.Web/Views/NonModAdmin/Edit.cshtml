<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">الاداريين خارج وزارة الدفاع</h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="container-fluid">
            <p class="text-muted">استخدم <a href="@Url.Action("Index","NonModAdmin")">صفحة الفهرس</a> لعرض وإدارة السجلات.</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function NewRecord(e) {
        if (e && e.model && e.model.isNew()) {
            $('.modal-title').text("إضافة جديدة");
        }
    }

    function showDetails(id) {
        $.ajax({
            url: '@Url.Action("GridDetails", "NonModAdmin")',
            data: { PligrimageId: id },
            success: function (html) {
                $('#detailsBody').html(html);
                $('#detailsModal').modal('show');
            }
        });
    }

    function error_handler(xhr) {
        toastr.error(xhr.responseText || 'حدث خطأ');
    }

    function request_end(type) {
        if (type === "update") toastr.success("تم تحديث البيانات بنجاح");
        if (type === "create") toastr.success("تم حفظ البيانات بنجاح");
        if (type === "delete") toastr.success("تم حذف البيانات بنجاح");
    }
</script>
}
