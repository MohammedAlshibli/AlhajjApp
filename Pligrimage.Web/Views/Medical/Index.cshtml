<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">الفحص الطبي</h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="mb-3">
            <a href="@Url.Action("Index","Injection")" class="btn btn-secondary btn-sm">
                <i class="fa fa-syringe"></i> سجلات التطعيم
            </a>
        </div>
        <div class="table-responsive">
            <table id="medicalTable" class="table table-bordered table-hover table-striped w-100">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الرقم العسكري</th>
                        <th>الرقم المدني</th>
                        <th>الوحدة</th>
                        <th>فصيلة الدم</th>
                        <th>حالة الفحص</th>
                        <th>تاريخ الحقن</th>
                        <th>ملاحظات الطبيب</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#medicalTable').DataTable({
            ajax: { url: '@Url.Action("ReadMedical","Medical")', dataSrc: '' },
            columns: [
                { data: 'fullName' },
                { data: 'servcieNumber' },
                { data: 'nic' },
                { data: 'unitNameAr' },
                { data: 'bloodGroup' },
                { data: 'fitResult' },
                { data: 'injectionDate' },
                { data: 'doctorNote' },
                {
                    data: 'pligrimageId', orderable: false,
                    render: function (id) {
                        return '<a href="@Url.Action("UpdateDoctorNote","Medical")?id=' + id +
                               '" class="btn btn-warning btn-xs"><i class="fa fa-pencil"></i> تعديل</a>';
                    }
                }
            ]
        });
    });
</script>
}
