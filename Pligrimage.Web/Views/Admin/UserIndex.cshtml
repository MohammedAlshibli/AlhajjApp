@model IEnumerable<Pligrimage.Web.Common.ViewModel.UserViewModel>

<link href="~/lib/font-awesome-4.7.0/css/font-awesome.css" rel="stylesheet" />

<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3"><span class="fa fa-users"></span> المستخدمين</h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="mb-3">
            <a href="@Url.Action("CreateUser","Admin")" class="btn btn-primary btn-sm">
                <i class="fa fa-plus"></i> إضافة مستخدم
            </a>
        </div>
        <div class="table-responsive">
            <table id="userTable" class="table table-bordered table-hover table-striped w-100">
                <thead>
                    <tr>
                        <th>اسم المستخدم</th>
                        <th>الرتبة والاسم</th>
                        <th>الحالة</th>
                        <th>تاريخ الإنشاء</th>
                        <th>عدد الصلاحيات</th>
                        <th>عدد الأسلحة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#userTable').DataTable({
            ajax: { url: '@Url.Action("GetAllUsers","Admin")', dataSrc: '' },
            columns: [
                { data: 'userName' },
                { data: 'fullName', render: function(d,t,r){ return (r.rank||'') + ' ' + (d||''); } },
                {
                    data: 'active',
                    render: function (v) {
                        return v ? "<span class='badge badge-success'>فعال</span>"
                                 : "<span class='badge badge-danger'>غير فعال</span>";
                    }
                },
                { data: 'createdOn', render: function(d){ return d ? new Date(d).toLocaleDateString('ar-SA') : ''; } },
                { data: 'roleCount' },
                { data: 'serivceCount' },
                {
                    data: 'userId', orderable: false,
                    render: function (id) {
                        return '<a href="@Url.Action("UserEditable","Admin")?userId=' + id +
                               '" class="btn btn-warning btn-xs"><i class="fa fa-pencil"></i> تعديل</a>';
                    }
                }
            ]
        });
    });
</script>
}
