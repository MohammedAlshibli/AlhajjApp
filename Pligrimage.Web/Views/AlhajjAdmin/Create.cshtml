@model Pligrimage.Entities.AlhajjMaster

@{
    ViewData["Title"] = "Create";
}

<h4 style="text-align:center"> اداريين وزارة الدفاع</h4>

<hr />

<div dir="rtl">
    <br />

    <div class="row">
        <div class=" col-md-4">
            <div class="row">

                <div class=" col-md-5">
                    <input type="text" class="form-control" name="getServiceNumber" value="" id="getServiceNumber" placeholder="أكتب الرقم العسكري" />

                </div>
                <div class=" col-md-4">
                    <button id="searchBtnDet" onclick="GetEmployee()" type="submit" class="btn btn-primary" style="height:35px;width:150px" >بحث</button>
                </div>
                <div class=" col-md-2">
                    <div id="spinner" class="form-group" style="display:none">
                        <div>
                            <img style="width:40px; height:40px;" src="~/Image/loading.gif" />
                        </div>
                    </div>
                </div>


            </div>
        </div>

        <div class=" col-md-2">
            <table class="table table-fixed w-auto table-info table-bordered">
                <thead>
                    <tr>
                        <th style="text-align:center">العدد المسموح</th>
                        <td style="text-align:center">
                            <div id="allowNumber"></div>
                        </td>
                        <th style="text-align:center">العدد الأحتياط</th>
                        <td style="text-align:center">
                            <div id="standBy"></div>
                        </td>
                    </tr>
                </thead>
            </table>
        </div>
    </div>





    <div dir="rtl" id="EmployeeDetailsView">

    </div>

