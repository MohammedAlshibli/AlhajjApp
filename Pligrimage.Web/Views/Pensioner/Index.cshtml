<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">بيانات المتقاعدين</h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="mb-3">
            <a href="@Url.Action("Create","Pensioner")" class="btn btn-primary btn-sm">
                <i class="fa fa-plus"></i> إضافة متقاعد
            </a>
        </div>
        <div class="table-responsive">
            <table id="pensionerTable" class="table table-bordered table-hover table-striped w-100">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الرقم العسكري</th>
                        <th>الرقم المدني</th>
                        <th>المحافظة</th>
                        <th>حالة الموظف</th>
                        <th>السلاح</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#pensionerTable').DataTable({
            ajax: { url: '@Url.Action("PensionerRead","Pensioner")', dataSrc: '' },
            columns: [
                { data: 'fullName' },
                { data: 'servcieNumber' },
                { data: 'nic' },
                { data: 'region' },
                { data: 'employeeStatus' },
                { data: 'unitNameAr' }
            ]
        });
    });
</script>
}
