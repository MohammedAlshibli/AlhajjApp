        <script>

            function NewRecord(e) {
                if (e.model.isNew()) {
                    $('.k-window-title').text("إضافة جديدة");
                }

            }


            function error_handler(e) {

                if ("#AlhajjNonModAdmin" !== "") {
                    alert("تجاوزت العدد المسموح به ")
                }
                console.log(e);
                if (e.errors) {
                    var message = "Errors: \n";
                    $.each(e.errors, function (key, value) {
                        if ('errors' in value) {
                            $.each(value.errors, function () {
                                message += this + "\n";
                            });
                        }
                    });
                    alert(message);
                }
            };

        </script>


        










