@model Pligrimage.Entities.AlhajjMaster



<div class="panel-body">
    <form asp-action="CreateAlhajjFromHrms" asp-controller="AlhajjMasters" method="POST" id="AlhajjMasterForm">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="PligrimageId" />
        <input type="hidden" asp-for="UnitId" />
        <input asp-for="RankCode" hidden />
        <input asp-for="WilayaCode" hidden />
        <input asp-for="VillageCode" hidden />
        <input type="hidden" asp-for="DateOfBirth" hidden />





        <div class="row">

            <div class=" col-md-6">
                <table class="table table-user-information ">
                    <tbody>



                        <tr>
                            <th>@Html.DisplayName("الاسم")</th>
                            <td><input class="form-control" readonly asp-for="FullName" /></td>
                            <td><input class="form-control align-items-center" readonly asp-for="Age" /></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayName("حالة الموظف")</th>
                            <td> <input asp-for="EmployeeStatus" /></td>

                        </tr>
                        <tr>
                            <th>@Html.DisplayName("الرقم العسكري")</th>
                            <td><input class="form-control" readonly asp-for="ServcieNumber" /></td>
                            <td><input class="form-control" readonly asp-for="RankDesc" /></td>

                        </tr>

                        <tr>
                            <th>@Html.DisplayName("السلاح")</th>
                            <td><input class="form-control" readonly asp-for="Unit.UnitNameAr" /></td>
                            <td><input class="form-control" readonly asp-for="HrmsUnitDesc" /></td>
                        </tr>



                        <tr>
                            <th>@Html.DisplayName("البطاقة الشخصية")</th>
                            <td><input class="form-control" type="text" asp-for="NIC" /></td>
                            <td><input class="form-control" type="datetime" asp-for="NICExpire" /></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayName("جواز السفر")</th>
                            <td><input class="form-control" type="text" asp-for="Passport" /></td>
                            <td><input class="form-control" type="datetime" asp-for="PassportExpire" /></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayName("السكن الدائم")</th>
                            <td><input class="form-control" readonly asp-for="Region" /></td>
                            <td><input class="form-control" readonly asp-for="WilayaDesc" /></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayName("ارقام الهواتف")</th>
                            <td><input class="form-control" readonly asp-for="WorkPhone" /></td>
                            <td><input class="form-control" readonly asp-for="GSM" /></td>

                        </tr>
                        <tr>
                            <th>@Html.DisplayName("فصيلة الدم")</th>
                            <td><input class="form-control" readonly asp-for="BloodGroup" /></td>
                        </tr>


                        <tr>
                            <th>@Html.DisplayName("نوع الحاج")</th>
@*                             <td> @Html.Kendo().DropDownListFor(model => model.ParameterId).DataTextField("DescArabic").DataValueField("ParameterId").BindTo((System.Collections.IEnumerable)ViewData["ClassTypeList"])</td>
 *@                        </tr>

                    </tbody>
                </table>
            </div>
            <div class=" col-md-6">
                <table class="table table-striped w-auto">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>الاسم اقرب الاقربين </th>
                            <th>رقم الهاتف</th>
                            <th>صلة القرابة</th>

                        </tr>

                    </thead>
                    <tbody>
                        <tr class="table-info">
                            <th scope="row">1</th>
                            <td><input type="text" class="form-control" asp-for="ReletiveName1" placeholder="الاسم" required /></td>
                            <td><input type="text" class="form-control" asp-for="RelativeGsm1" placeholder="الاسم" required /></td>
                            @*<td> @Html.Kendo().DropDownListFor(model => model.ReletiveCode1).DataTextField("DescArabic").DataValueField("ParameterId").BindTo((System.Collections.IEnumerable)ViewData["RTNCodeList"])</td>*@
                        </tr>

                        <tr class="table-info">
                            <th scope="row">2</th>
                            <td><input type="text" class="form-control" asp-for="ReletiveName2" placeholder="الاسم" required /></td>
                            <td><input type="text" class="form-control" asp-for="RelativeGsm2" placeholder="الاسم" required /></td>
                            @*<td> @Html.Kendo().DropDownListFor(model => model.ReletiveCode2).DataTextField("DescArabic").DataValueField("ParameterId").BindTo((System.Collections.IEnumerable)ViewData["RTNCodeList"])</td>*@
                        </tr>

                    </tbody>


                </table>
            </div>

            <div class="form-group">

                <button type="submit" class="btn btn-primary"> حفظ</button>
            </div>

            <div>
                <input type="button" class="btn btn-info" value="القوائم" onclick="location.href='@Url.Action("Index","AlhajjMasters")'" />

            </div>

        </div>
    </form>
</div>



@* <div>
    @(Html.Kendo().Notification()
                                                    .Name("WSNotification")
                                                    .HideOnClick(true)
                                                    .AutoHideAfter(5000)
                                                    .Position(c => c.Top(30).Right(30))
    )
</div> *@


<script>
    

    $('#AlhajjMasterForm').submit(function (e) {

        e.preventDefault();
        if ($("#NIC").val() == 'لايوجد') {
            $("#NIC").addClass("border border-danger");
        }

        $.ajax({
            url: this.action,    //Url.Action("GetAlhajjDataFormWebService", "AlhajjMasters")
            type: this.method,
            data: $(this).serialize(),  // { ServiceNumber: $("#ServiceNumber").val() }
            //   dataType: "JSON",
            success: function (data) {

                toastr.success("تمت الإضافة بنجاح");
                $("#ServiceNumber").val("");

            },
            error: function (xhr, status, error) {

                toastr.error(xhr.responseText || "حدث خطأ");



            }



        });

    });

</script>