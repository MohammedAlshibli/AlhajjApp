@{
    ViewData["Title"] = "الموافقة المركزية — الإدارة العليا";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
:root{--navy:#0f2942;--blue:#1a3a5c;--gold:#c9a227;--green:#059669;--red:#dc2626;--orange:#ea580c;}
.hq-header{background:linear-gradient(135deg,#0f2942 0%,#1e4976 100%);border-radius:14px;padding:24px 28px;color:#fff;margin-bottom:22px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 24px rgba(15,41,66,.4);}
.hq-header h4{margin:0;font-size:20px;font-weight:800;}
.hq-header .sub{font-size:13px;opacity:.7;margin-top:3px;}
.stat-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:22px;}
.stat-card{background:#fff;border-radius:12px;padding:16px;text-align:center;box-shadow:0 1px 8px rgba(0,0,0,.07);border:1px solid #e2e8f0;}
.stat-card .num{font-size:30px;font-weight:800;line-height:1;}
.stat-card .lbl{font-size:11px;color:#64748b;margin-top:4px;}
.unit-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-bottom:22px;}
.unit-card{background:#fff;border-radius:10px;padding:14px 16px;border:1.5px solid #e2e8f0;cursor:pointer;transition:all .2s;}
.unit-card:hover,.unit-card.active{border-color:var(--blue);background:#eff6ff;}
.unit-card .uc-name{font-weight:700;font-size:14px;color:#1e293b;}
.unit-card .uc-num{font-size:22px;font-weight:800;color:var(--blue);line-height:1;margin-top:4px;}
.unit-card .uc-sub{font-size:11px;color:#64748b;margin-top:3px;}
.toolbar{background:#fff;border-radius:12px;padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;box-shadow:0 1px 6px rgba(0,0,0,.06);border:1px solid #e2e8f0;}
.approve-bar{background:linear-gradient(135deg,#ecfdf5,#d1fae5);border:1.5px solid #6ee7b7;border-radius:10px;padding:12px 18px;margin-bottom:16px;display:none;align-items:center;gap:12px;}
.approve-bar.show{display:flex;}
.badge-pill{padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;white-space:nowrap;}
.b-confirmed{background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;}
.b-pending{background:#f1f5f9;color:#475569;border:1px solid #cbd5e1;}
.b-returned{background:#fef3c7;color:#92400e;border:1px solid #fcd34d;}
.b-hq{background:#dbeafe;color:#1e40af;border:1px solid #93c5fd;}
.b-fit{background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;}
.b-notfit{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;}
.b-waiting{background:#fef9c3;color:#854d0e;border:1px solid #fde047;}
.b-original{background:#dbeafe;color:#1e40af;border:1px solid #93c5fd;}
.b-standby{background:#fef9c3;color:#854d0e;border:1px solid #fde047;}
.return-modal .modal-header{background:linear-gradient(135deg,#92400e,#d97706);color:#fff;border-radius:8px 8px 0 0;}
tr.row-hq td{background:#f0f9ff!important;}
.pp-danger{color:var(--red);font-weight:700;}
.pp-warn{color:var(--orange);font-weight:600;}
.pp-ok{color:var(--green);}
</style>

<!-- HEADER -->
<div class="hq-header">
  <div>
    <h4>🏛️ الموافقة المركزية — الإدارة العليا</h4>
    <div class="sub">عرض جميع الحجاج المؤكدين من الأسلحة — موسم الحج <span id="hqYear">…</span></div>
  </div>
  <div class="d-flex align-items-center" style="gap:10px">
    <span class="badge" style="background:var(--gold);color:#fff;padding:6px 16px;border-radius:20px;font-size:13px;font-weight:700;">
      إجمالي المؤكدين: <span id="hqTotalBadge">…</span>
    </span>
    <button class="btn btn-light btn-sm" onclick="refreshAll()"><i class="fa fa-refresh"></i> تحديث</button>
  </div>
</div>

<!-- STATS -->
<div class="stat-grid">
  <div class="stat-card"><div class="num" id="sTotal"   style="color:var(--blue)">—</div><div class="lbl">إجمالي المؤكدين من الأسلحة</div></div>
  <div class="stat-card"><div class="num" id="sPending" style="color:#64748b">—</div><div class="lbl">في انتظار تأكيد الأسلحة</div></div>
  <div class="stat-card"><div class="num" id="sHQ"      style="color:var(--green)">—</div><div class="lbl">تمت الموافقة النهائية</div></div>
  <div class="stat-card"><div class="num" id="sReturn"  style="color:var(--orange)">—</div><div class="lbl">مُعادون للمراجعة</div></div>
  <div class="stat-card"><div class="num" id="sPassport" style="color:var(--red)">—</div><div class="lbl">جوازات تحتاج تجديد</div></div>
</div>

<!-- UNIT CARDS -->
<div id="unitGrid" class="unit-grid"></div>

<!-- BULK APPROVE BANNER -->
<div class="approve-bar" id="approveBar">
  <span style="font-size:20px">✅</span>
  <div><strong><span id="selCount">0</span> سجل محدد</strong></div>
  <button class="btn btn-success btn-sm mr-auto" onclick="finalApproveSelected()">
    <i class="fa fa-check-double"></i> موافقة نهائية للمحددين
  </button>
  <button class="btn btn-light btn-sm" onclick="clearSel()">إلغاء التحديد</button>
</div>

<!-- TOOLBAR -->
<div class="toolbar">
  <button class="btn btn-primary btn-sm" id="btnApproveAll" onclick="finalApproveAll()">
    <i class="fa fa-check-circle"></i> موافقة نهائية على الجميع
  </button>
  <button class="btn btn-warning btn-sm" onclick="selectAll()">
    <i class="fa fa-list-ul"></i> تحديد الكل
  </button>
  <span id="selBadge" class="badge badge-primary" style="display:none"></span>
  <div class="mr-auto d-flex" style="gap:8px">
    <select id="unitFilter" class="form-control form-control-sm" style="width:200px" onchange="filterUnit()">
      <option value="">كل الأسلحة</option>
    </select>
    <input id="searchBox" class="form-control form-control-sm" style="width:220px" placeholder="🔍 بحث…" oninput="applySearch()">
    <button class="btn btn-outline-secondary btn-sm" onclick="exportExcel()"><i class="fa fa-file-excel-o"></i></button>
    <button class="btn btn-outline-secondary btn-sm" onclick="printTable()"><i class="fa fa-print"></i></button>
  </div>
</div>

<!-- TABLE -->
<div class="card card-cascade wider">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table id="centralTable" class="table table-bordered table-hover w-100" style="font-size:13px">
        <thead>
          <tr>
            <th style="width:36px"><input type="checkbox" id="chkAll"></th>
            <th>#</th><th>الاسم</th><th>الرقم العسكري</th><th>الهوية</th>
            <th>الرتبة</th><th>السلاح / الوحدة</th><th>رقم الجواز</th>
            <th>انتهاء الجواز</th><th>نوع الحاج</th><th>الحالة</th><th>الإجراءات</th>
          </tr>
        </thead>
      </table>
    </div>
  </div>
</div>

<!-- RETURN MODAL -->
<div class="modal fade return-modal" id="returnModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fa fa-undo ml-2"></i> إعادة الطلب إلى السلاح</h5>
        <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="retId">
        <div class="alert alert-warning py-2 mb-3">
          سيُعاد طلب <strong id="retName"></strong> إلى سلاح <strong id="retUnit"></strong> للمراجعة والتعديل.
        </div>
        <div class="form-group mb-0">
          <label class="font-weight-bold">سبب الإعادة</label>
          <textarea id="retNote" class="form-control" rows="3" placeholder="اكتب سبب الإعادة للسلاح…"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-warning" onclick="submitReturn()"><i class="fa fa-undo"></i> إعادة للسلاح</button>
        <button class="btn btn-secondary" data-dismiss="modal">إغلاق</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function(){
  'use strict';
  var READ_URL    = '@Url.Action("ReadConfirmed","CentralConfirm")';
  var STATS_URL   = '@Url.Action("GetStats","CentralConfirm")';
  var APPROVE_ALL = '@Url.Action("FinalApproveAll","CentralConfirm")';
  var APPROVE_SEL = '@Url.Action("FinalApproveSelected","CentralConfirm")';
  var RETURN_URL  = '@Url.Action("ReturnToBranch","CentralConfirm")';
  var token       = $('input[name="__RequestVerificationToken"]').val();

  var dt, currentUnit = '';

  // ── Helpers ─────────────────────────────────────────────────
  function ppStatus(s){
    if(!s) return {level:'none'};
    var d=new Date(s), now=new Date();
    var days=Math.floor((d-now)/86400000);
    var mo=(d.getFullYear()-now.getFullYear())*12+(d.getMonth()-now.getMonth());
    if(days<0)  return{level:'expired',days:days,icon:'🔴',cls:'pp-danger',lbl:'منتهي'};
    if(mo<6)    return{level:'critical',days:days,icon:'🟠',cls:'pp-danger',lbl:days+' يوم'};
    if(mo<9)    return{level:'warning',days:days,icon:'🟡',cls:'pp-warn',lbl:days+' يوم'};
    return{level:'ok',days:days,icon:'🟢',cls:'pp-ok',lbl:'صالح'};
  }
  function ppHtml(s){var p=ppStatus(s);if(p.level==='none')return'—';return'<span class="'+p.cls+'">'+p.icon+' '+p.lbl+'</span>';}
  function statusBadge(c){
    if(c===77)  return '<span class="badge-pill b-hq">✓ موافقة نهائية</span>';
    if(c===51)  return '<span class="badge-pill b-confirmed">✓ مؤكد من السلاح</span>';
    if(c===0)   return '<span class="badge-pill b-pending">⏳ انتظار</span>';
    return '<span class="badge-pill b-returned">↩ مُعاد</span>';
  }
  function typeBadge(p){
    if(p===1) return '<span class="badge-pill b-original">أصلي</span>';
    if(p===2) return '<span class="badge-pill b-standby">احتياط</span>';
    return '<span class="badge-pill b-waiting">إداري</span>';
  }

  // ── Init DataTable ───────────────────────────────────────────
  function initTable(){
    dt = $('#centralTable').DataTable({
      ajax:{url:READ_URL, dataSrc:'', error:function(){toastr.error('فشل تحميل البيانات');}},
      columns:[
        {data:null,orderable:false,className:'text-center',render:function(d,t,r){
          if(r.confirmCode===77) return '<span class="text-success">✓</span>';
          return '<input type="checkbox" class="row-chk" data-id="'+r.pligrimageId+'" data-name="'+(r.fullName||'')+'" data-unit="'+(r.unitNameAr||'')+'">';
        }},
        {data:null,render:function(d,t,r,m){return m.row+1;},orderable:false},
        {data:'fullName',render:function(d){return'<span style="font-weight:600">'+d+'</span>';}},
        {data:'servcieNumber',render:function(d){return'<code>'+d+'</code>';}},
        {data:'nic'},
        {data:'rankDesc'},
        {data:'unitNameAr',render:function(d){return'<span class="badge badge-light border">'+d+'</span>';}},
        {data:'passport',render:function(d){return'<code>'+(d||'—')+'</code>';}},
        {data:'passportExpire',render:function(d){return ppHtml(d);}},
        {data:'parameterId',render:function(d){return typeBadge(d);}},
        {data:'confirmCode',render:function(d){return statusBadge(d);}},
        {data:null,orderable:false,className:'text-center',render:function(d,t,r){
          var btns='';
          if(r.confirmCode===51){
            btns+='<button class="btn btn-success btn-xs ml-1 btn-approve" data-id="'+r.pligrimageId+'" title="موافقة نهائية"><i class="fa fa-check"></i></button>';
          }
          if(r.confirmCode!==77){
            btns+='<button class="btn btn-warning btn-xs btn-return" data-id="'+r.pligrimageId+'" data-name="'+(r.fullName||'')+'" data-unit="'+(r.unitNameAr||'')+'" title="إعادة للسلاح"><i class="fa fa-undo"></i></button>';
          }
          return btns||'<span class="text-muted">—</span>';
        }}
      ],
      rowCallback:function(row,data){$(row).toggleClass('row-hq', data.confirmCode===77);},
      language:{url:'//cdn.datatables.net/plug-ins/1.13.8/i18n/ar.json',emptyTable:'لا توجد سجلات مؤكدة من الأسلحة'},
      order:[[10,'asc']],pageLength:25,responsive:true,
      dom:'Bfrtip',
      buttons:[
        {extend:'excel',text:'<i class="fa fa-file-excel-o"></i>',className:'btn-sm btn-outline-secondary',title:'الموافقة المركزية'},
        {extend:'print',text:'<i class="fa fa-print"></i>',className:'btn-sm btn-outline-secondary',title:'الموافقة المركزية'}
      ]
    });
    dt.on('draw',updateSel);
  }

  // ── Stats + unit cards ───────────────────────────────────────
  function loadStats(){
    $.getJSON(STATS_URL,function(s){
      $('#sTotal').text(s.branchConfirmed);
      $('#sPending').text(s.pending);
      $('#sHQ').text(s.returned);
      $('#sReturn').text(s.returned);
      $('#sPassport').text(s.passportIssues);
      $('#hqTotalBadge').text(s.branchConfirmed);
      $('#hqYear').text(new Date().getFullYear());

      // Unit cards
      var $grid=$('#unitGrid').empty();
      var $sel=$('#unitFilter');
      $sel.find('option:not(:first)').remove();
      s.byUnit.forEach(function(u){
        $grid.append(
          '<div class="unit-card'+(currentUnit===u.unit?' active':'')+'" onclick="filterUnit(\''+u.unit+'\')" >'+
          '<div class="uc-name">'+u.unit+'</div>'+
          '<div class="uc-num">'+u.count+'</div>'+
          '<div class="uc-sub">أصلي: '+u.original+' | احتياط: '+u.standby+(u.passport?' | ⚠️ جوازات: '+u.passport:'')+'</div>'+
          '</div>'
        );
        $sel.append('<option value="'+u.unit+'">'+u.unit+'</option>');
      });
    });
  }

  // ── Filter by unit ───────────────────────────────────────────
  window.filterUnit=function(unit){
    currentUnit=unit||$('#unitFilter').val()||'';
    $('.unit-card').toggleClass('active',false);
    if(currentUnit) $('.unit-card').filter(function(){return $(this).find('.uc-name').text()===currentUnit;}).addClass('active');
    dt.column(6).search(currentUnit||'').draw();
  };
  window.applySearch=function(){dt.search($('#searchBox').val()).draw();};

  // ── Selection ────────────────────────────────────────────────
  $('#centralTable').on('change','.row-chk',updateSel);
  $('#chkAll').on('change',function(){$('#centralTable tbody .row-chk:visible').prop('checked',this.checked);updateSel();});
  function updateSel(){
    var n=$('#centralTable tbody .row-chk:checked').length;
    $('#selBadge').text(n+' محدد').toggle(n>0);
    $('#approveBar').toggleClass('show',n>0);
    $('#selCount').text(n);
  }
  window.updateSel=updateSel;
  window.clearSel=function(){$('#centralTable tbody .row-chk,#chkAll').prop('checked',false);updateSel();};
  window.selectAll=function(){$('#centralTable tbody .row-chk:visible').prop('checked',true);updateSel();};

  // ── Approve all ──────────────────────────────────────────────
  window.finalApproveAll=function(){
    if(!confirm('الموافقة النهائية على جميع الحجاج المؤكدين من الأسلحة؟')) return;
    $.post(APPROVE_ALL,{__RequestVerificationToken:token},function(r){
      toastr.success(r.message);refreshAll();
    }).fail(function(x){toastr.error(x.responseText||'فشلت العملية');});
  };

  // ── Approve selected ─────────────────────────────────────────
  window.finalApproveSelected=function(){
    var ids=$('#centralTable tbody .row-chk:checked').map(function(){return+$(this).data('id');}).get();
    if(!ids.length) return;
    $.ajax({url:APPROVE_SEL,method:'POST',contentType:'application/json',
      headers:{'RequestVerificationToken':token},data:JSON.stringify(ids),
      success:function(r){toastr.success(r.message);clearSel();refreshAll();},
      error:function(x){toastr.error(x.responseText||'فشلت العملية');}
    });
  };

  // ── Approve single ───────────────────────────────────────────
  $('#centralTable').on('click','.btn-approve',function(){
    var id=[+$(this).data('id')];
    $.ajax({url:APPROVE_SEL,method:'POST',contentType:'application/json',
      headers:{'RequestVerificationToken':token},data:JSON.stringify(id),
      success:function(r){toastr.success(r.message);refreshAll();},
      error:function(x){toastr.error(x.responseText||'فشلت العملية');}
    });
  });

  // ── Return to branch ─────────────────────────────────────────
  $('#centralTable').on('click','.btn-return',function(){
    $('#retId').val($(this).data('id'));
    $('#retName').text($(this).data('name'));
    $('#retUnit').text($(this).data('unit'));
    $('#retNote').val('');
    $('#returnModal').modal('show');
  });
  window.submitReturn=function(){
    var id=$('#retId').val(), note=$('#retNote').val().trim();
    $.post(RETURN_URL,{pligrimageId:id,returnNote:note,__RequestVerificationToken:token},
      function(r){toastr.success(r.message);$('#returnModal').modal('hide');refreshAll();})
     .fail(function(x){toastr.error(x.responseText||'فشل الإرجاع');});
  };

  // ── Refresh + export ─────────────────────────────────────────
  window.refreshAll=function(){dt.ajax.reload(null,false);loadStats();};
  window.exportExcel=function(){dt.button(0).trigger();};
  window.printTable=function(){dt.button(1).trigger();};

  // ── Init ─────────────────────────────────────────────────────
  $(function(){
    initTable(); loadStats();
    toastr.options={positionClass:'toast-top-left',timeOut:3000,rtl:true};
  });
}());
</script>}
