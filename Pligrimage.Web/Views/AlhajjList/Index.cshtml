    <script type="text/javascript">

        function TypeChange(typeName) {
            if (!$.fn.DataTable.isDataTable('#AlhajjMasterGrid')) return;
            var grid = $('#AlhajjMasterGrid').DataTable();
            grid.search(typeName || '').draw();
        }

    </script>

