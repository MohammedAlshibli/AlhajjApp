                .Position(c => c.Top(50).Right(30))
        )
    </div> *@


    <script src="~/lib/jquery/dist/jquery.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>

    

    $(document).ready(function () {
        GetServiceCount();

    });

        function GetEmployee() {

         $.ajax({
            url: '@Url.Action("GetAlhajjDataFormWebService", "AlhajjAdmin")',
            type: 'Get',
            dataType: 'html',
            data: {
                ServiceNumber: $('#getServiceNumber').val(),

            },
            beforeSend: function () {
                $("#spinner").show();
            },
             success: function (data) {

                $("#spinner").hide();
                $("#EmployeeDetailsView").html(data);
                 toastr.success("تم جلب البيانات بنجاح");
                 $("#getServiceNumber").val("");
            },

             complete: function (data) {

                $("#spinner").hide();

             },

             onerror: function (data) {
                 alert("error");


             }
        });



    }


  function GetServiceCount() {
        $.ajax({
            url: '@Url.Action("StaticService", "AlhajjAdmin")',
            type: 'Get',
            dataType: 'json',
            contentType: "application/json; charset=utf-8",


            success: function (data, i) {
                debugger;
                console.log('data',data)
                var allowNumber = data[0].consumed + " من " + data[0].total;
                if (data[0].Consumed == data[0].Total) {
                    $("#allowNumber").addClass("text-danger");
                }
                $("#allowNumber").html(allowNumber);


                var SatndByNumber = data[1].consumed + " من " + data[1].total;
                if (data[1].Consumed == data[1].Total) {
                    $("standBy").addClass("text-danger");

                }
                $("#standBy").html(SatndByNumber);
            },



        });


    }

    </script>
