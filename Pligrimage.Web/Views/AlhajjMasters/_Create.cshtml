    @(Html.Kendo().Notification()
                                                    .Name("WSNotification")
                                                    .HideOnClick(true)
                                                    .AutoHideAfter(5000)
                                                    .Position(c => c.Top(30).Right(30))
    )
</div> *@


<script>
    

    $('#AlhajjMasterForm').submit(function (e) {

        e.preventDefault();
        if ($("#NIC").val() == 'لايوجد') {
            $("#NIC").addClass("border border-danger");
        }

        $.ajax({
            url: this.action,    //Url.Action("GetAlhajjDataFormWebService", "AlhajjMasters")
            type: this.method,
            data: $(this).serialize(),  // { ServiceNumber: $("#ServiceNumber").val() }
            //   dataType: "JSON",
            success: function (data) {

                toastr.success("تمت الإضافة بنجاح");
                $("#ServiceNumber").val("");
                window.location.href = '@Url.Action("Index", "AlhajjMasters")';

            },
            error: function (xhr, status, error) {

                toastr.error(xhr.responseText || "حدث خطأ");



            }



        });

    });

</script>