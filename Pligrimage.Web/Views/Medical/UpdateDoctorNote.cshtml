
@model Pligrimage.Entities.AlhajjMaster

@{
    ViewData["Title"] = "UpdateDoctorNote";
}


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="UpdateDoctorNote">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="PligrimageId" />
            <div class="form-group">
                <label asp-for="ServcieNumber" class="control-label"></label>
                <input asp-for="ServcieNumber" class="form-control" />
                <span asp-validation-for="ServcieNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NIC" class="control-label"></label>
                <input asp-for="NIC" class="form-control" />
                <span asp-validation-for="NIC" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DoctorNote" class="control-label"></label>
                <textarea asp-for="DoctorNote" class="form-control"></textarea>
                <span asp-validation-for="DoctorNote" class="text-danger"></span>
            </div>

   

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
