@model IEnumerable<Pligrimage.Entities.AlhajjMaster>
@{
    ViewData["Title"] = "IndexMedical";
}



<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">الفحص الطبي</h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="k-rtl">

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.ServcieNumber)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.FullName)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.NIC)
                        </th>

                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.ServcieNumber)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.FullName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Parameter.DescArabic)
                            </td>

                            <td>
                                <a asp-action="UpdateDoctorNote" class="btn btn-success" asp-route-id="@item.PligrimageId"><i class="fa fa-edit"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    <style>
        .card-body {
            -webkit-box-flex: 2;
            -ms-flex: 1 1 auto;
            flex: 1 1 auto;
            padding: 2.25rem;
        }
    </style>