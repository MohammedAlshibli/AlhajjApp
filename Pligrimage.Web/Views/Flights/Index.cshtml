<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">الرحلات الجوية <i class="fa fa-plane" aria-hidden="true"></i></h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="mb-3">
            <a href="@Url.Action("CreateFlight","Flights")" class="btn btn-primary btn-sm">
                <i class="fa fa-plus"></i> إضافة رحلة
            </a>
        </div>
        <div class="table-responsive">
            <table id="flightTable" class="table table-bordered table-hover table-striped w-100">
                <thead>
                    <tr>
                        <th>رقم الرحلة</th>
                        <th>تاريخ المغادرة</th>
                        <th>تاريخ الوصول</th>
                        <th>السعة</th>
                        <th>نوع الرحلة</th>
                        <th>الوجهة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#flightTable').DataTable({
            ajax: { url: '@Url.Action("FlightRead","Flights")', dataSrc: '' },
            columns: [
                { data: 'flightNo' },
                { data: 'flightDate' },
                { data: 'arriveDate' },
                { data: 'flightCapacity' },
                { data: 'flightType' },
                { data: 'direction' },
                {
                    data: 'flightId', orderable: false,
                    render: function (id) {
                        return '<a href="@Url.Action("EditFlight","Flights")/' + id +
                               '" class="btn btn-warning btn-xs"><i class="fa fa-pencil"></i> تعديل</a> ' +
                               '<button onclick="deleteFlight(' + id + ')" class="btn btn-danger btn-xs"><i class="fa fa-trash"></i> حذف</button>';
                    }
                }
            ]
        });
    });

    function deleteFlight(id) {
        if (!confirm('هل تريد حذف هذه الرحلة؟')) return;
        $.post('@Url.Action("DeleteFlight","Flights")', { flightId: id }, function () {
            toastr.success('تم حذف الرحلة بنجاح');
            $('#flightTable').DataTable().ajax.reload();
        }).fail(function () { toastr.error('حدث خطأ'); });
    }
</script>
}
