<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">الاداريين خارج وزارة الدفاع</h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="mb-3">
            <a href="@Url.Action("Create","NonModAdmin")" class="btn btn-primary btn-sm">
                <i class="fa fa-plus"></i> إضافة جديدة
            </a>
        </div>
        <div class="table-responsive">
            <table id="nonModTable" class="table table-bordered table-hover table-striped w-100">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الرقم العسكري</th>
                        <th>الرقم المدني</th>
                        <th>جواز السفر</th>
                        <th>المحافظة</th>
                        <th>السلاح</th>
                        <th>التصنيف</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#nonModTable').DataTable({
            ajax: { url: '@Url.Action("ReadNonModAdmin","NonModAdmin")', dataSrc: '' },
            columns: [
                { data: 'fullName' },
                { data: 'servcieNumber' },
                { data: 'nic' },
                { data: 'passport' },
                { data: 'region' },
                { data: 'unitNameAr' },
                { data: 'categoryDesc' },
                {
                    data: 'pligrimageId', orderable: false,
                    render: function (id) {
                        return '<a href="@Url.Action("Edit","NonModAdmin")?pligrimageId=' + id +
                               '" class="btn btn-warning btn-xs"><i class="fa fa-pencil"></i> تعديل</a> ' +
                               '<button onclick="deleteRecord(' + id + ')" class="btn btn-danger btn-xs"><i class="fa fa-trash"></i> حذف</button>';
                    }
                }
            ]
        });
    });

    function deleteRecord(id) {
        if (!confirm('هل تريد حذف هذا السجل؟')) return;
        $.post('@Url.Action("DeleteNonModAdmin","NonModAdmin")', { pligrimageId: id }, function () {
            toastr.success('تم الحذف بنجاح');
            $('#nonModTable').DataTable().ajax.reload();
        }).fail(function (xhr) { toastr.error(xhr.responseText || 'تجاوزت العدد المسموح به'); });
    }
</script>
}
