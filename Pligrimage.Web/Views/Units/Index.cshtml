<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">الوحدة / الادارة / الفئة</h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="mb-3">
            <a href="@Url.Action("Create","Units")" class="btn btn-primary btn-sm">
                <i class="fa fa-plus"></i> إضافة وحدة
            </a>
        </div>
        <div class="table-responsive">
            <table id="unitTable" class="table table-bordered table-hover table-striped w-100">
                <thead>
                    <tr>
                        <th>الوحدة</th>
                        <th>تصنيف الوحدة</th>
                        <th>العدد المسموح</th>
                        <th>الاحتياط</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#unitTable').DataTable({
            ajax: { url: '@Url.Action("UnitRead","Units")', dataSrc: '' },
            columns: [
                { data: 'unitNameAr' },
                {
                    data: 'modFlag',
                    render: function (v) {
                        return v ? "<span class='badge badge-danger'>وزارة الدفاع</span>"
                                 : "<span class='badge badge-success'>خارج وزارة الدفاع</span>";
                    }
                },
                { data: 'allowNumber' },
                { data: 'standBy' },
                {
                    data: 'unitId', orderable: false,
                    render: function (id) {
                        return '<a href="@Url.Action("Edit","Units")/' + id +
                               '" class="btn btn-warning btn-xs"><i class="fa fa-pencil"></i> تعديل</a> ' +
                               '<button onclick="deleteUnit(' + id + ')" class="btn btn-danger btn-xs"><i class="fa fa-trash"></i> حذف</button>';
                    }
                }
            ]
        });
    });

    function deleteUnit(id) {
        if (!confirm('هل تريد حذف هذه الوحدة؟')) return;
        $.post('@Url.Action("DeleteUnit","Units")', { unitId: id }, function () {
            toastr.success('تم الحذف بنجاح');
            $('#unitTable').DataTable().ajax.reload();
        }).fail(function () { toastr.error('حدث خطأ'); });
    }
</script>
}
