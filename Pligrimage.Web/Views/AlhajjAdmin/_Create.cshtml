<div>
    @(Html.Kendo().Notification()
                                                    .Name("WSNotification")
                                                    .HideOnClick(true)
                                                    .AutoHideAfter(20000)
                                                    .Position(c => c.Top(30).Right(30))
    )
</div> *@


<script>
    

    $('#AlhajjMasterForm').submit(function (e) {

        e.preventDefault();
        if ($("#NIC").val() == 'لايوجد') {
            alert("not yet")
            $("#NIC").addClass("border border-danger");
        }
        //if ($("#PassportExpire").val() == 'منتهي') {
        //    $("#PassportExpire").addClass("border border-danger")
        //}

        $.ajax({
            url: this.action,  
            type: this.method,
            data: $(this).serialize(), 
            success: function (data) {

                toastr.success("تمت الإضافة بنجاح");
                $("#ServiceNumber").val("");
                window.location.href = '@Url.Action("Index", "AlhajjAdmin")';

            },
            error: function (xhr, status, error) {

                console.log(xhr);
                toastr.error(xhr.responseText || "حدث خطأ");



            }



        });

    });

</script>