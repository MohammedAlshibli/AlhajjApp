<link href="~/lib/font-awesome-4.7.0/css/font-awesome.css" rel="stylesheet" />

<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">الحافلات <span class="fa fa-bus"></span></h2>
    </div>
    <div class="card-body card-body-cascade">
        <div class="mb-3">
            <a href="@Url.Action("CreateBus","Buses")" class="btn btn-primary btn-sm">
                <i class="fa fa-plus"></i> إضافة حافلة
            </a>
        </div>
        <div class="table-responsive">
            <table id="busTable" class="table table-bordered table-hover table-striped w-100">
                <thead>
                    <tr>
                        <th>رقم الباص</th>
                        <th>عدد الركاب</th>
                        <th>التاريخ</th>
                        <th>رقم الرحلة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#busTable').DataTable({
            ajax: {
                url: '@Url.Action("BusRead", "Buses")',
                dataSrc: ''
            },
            columns: [
                { data: 'busNo', title: 'رقم الباص' },
                { data: 'busCapacity', title: 'عدد الركاب' },
                { data: 'date', title: 'التاريخ',
                  render: function(d){ return d ? new Date(d).toLocaleDateString('ar-SA') : ''; } },
                { data: 'flightId', title: 'رقم الرحلة' },
                {
                    data: 'busId',
                    title: 'الإجراءات',
                    orderable: false,
                    render: function (id) {
                        return '<a href="@Url.Action("EditBus","Buses")/' + id +
                               '" class="btn btn-warning btn-xs"><i class="fa fa-pencil"></i> تعديل</a> ' +
                               '<button onclick="deleteBus(' + id + ')" class="btn btn-danger btn-xs"><i class="fa fa-trash"></i> حذف</button>';
                    }
                }
            ]
        });
    });

    function deleteBus(id) {
        if (!confirm('هل تريد حذف هذا السجل؟')) return;
        $.post('@Url.Action("DeleteBus","Buses")', { busId: id }, function () {
            toastr.success('تم الحذف بنجاح');
            $('#busTable').DataTable().ajax.reload();
        }).fail(function () { toastr.error('حدث خطأ أثناء الحذف'); });
    }
</script>
}
