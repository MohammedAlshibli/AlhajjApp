
<div class="card card-cascade wider">
    <div class="view view-cascade gradient-card-header blue-gradient-rgba">
        <h2 class="card-header-title mb-3">توزيع الحجاج </h2>
    </div>
    <div class="card-body card-body-cascade">

        <div class=" k-rtl">
            @(Html.Kendo().Grid<Pligrimage.Entities.Passenger>
    ()
    .Name("AlhajjGrid")
    .Columns(column =>
    {
        //column.Select().Width(50);
        column.Bound(c => c.FlightId).Title("رقم الرحلة");
        column.Bound(c => c.BusId).Title("رقم الباص");
        column.Bound(c => c.PassengerId);
        column.Bound(c => c.PligrimageId);

        column.Command(com =>
        {
            com.Edit().UpdateText("حفظ").Text("تعديل").CancelText("إلغاء").HtmlAttributes(new { type = "button", @class = "btn-basic ", });
        }).Width(200);

    })
    .PersistSelection(true)
    .ToolBar(c => c.Custom().Name("Save").Text(" توزيع الحجاج على الرحلات").IconClass("save").HtmlAttributes(new { onclick = "CreateAlhajjNonMod()" })
    )
    .Editable(editable => editable.Mode(GridEditMode.PopUp).TemplateName("Edit"))
    .DataSource
    (dataSourec => dataSourec
    .Ajax()
    .Model(m =>
    {
        m.Id(i => i.PassengerId);
    })
    .Read(read => read.Action("PassengerRead", "Passengers"))
    .Update(update => update.Action("UpdatePassenger", "Passengers"))

    )

    .Scrollable()
    .Sortable()
    .Selectable()
    .Filterable(f => f.Extra(false)
    .Operators(opertor => opertor
    .ForString(str => str.Clear()
    .Contains("يحتوي على"))))
    .Pageable
    (p => p
    .ButtonCount(5)
    .Refresh(true)
    ))





</div>

    </div>
    </div>







    

