@model IEnumerable<Pligrimage.Web.Models.StaticServiceViewModel>

<link href="~/odometer/odometer-theme-default.css" rel="stylesheet" />
<script src="~/odometer/odometer.js"></script>

<style>
    .odometer {
        font-size: 30px;
    }
</style>

<div class="panel panel-default " style="width:40%">
    <div class="panel-heading" style="background-color: #acaeb1">
        <div class="panel-title pull-ce">
            <div style="font-size:25px">إسلحة قوات السلطان المسلحة </div>
        </div>

        <div class="clearfix" style="height:100%"></div>
    </div>
    <table class="table  table-hover table-bordered table-striped " style="width:100%">
        <thead>
            <tr>
                <th>
                    اسم السلاح
                </th>
                <th>
                    العدد المسموح
                </th>
                <th>
                    المتبقي
                </th>

                <th>
                    عدد الاحتياط
                </th>
                <th>
                    المتبقي
                </th>


            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.ServiceName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.AllowNumber)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.AllowNumberRemming)
                    </td>

                    <td>
                        @Html.DisplayFor(modelItem => item.StandBy)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StandByRemming)
                    </td>
                    @*<td>
                            @Html.DisplayFor(modelItem => item.Count)
                        </td>*@

                </tr>
            }
        </tbody>
    </table>

</div>
@{Html.RenderPartial("_StaticByServise");}