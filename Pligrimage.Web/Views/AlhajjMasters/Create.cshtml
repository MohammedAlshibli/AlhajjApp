@model Pligrimage.Entities.AlhajjMaster
@{
    ViewData["Title"] = "تسجيل حاج جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
:root{--navy:#0f2942;--blue:#1a3a5c;--gold:#c9a227;--green:#059669;--red:#dc2626;--orange:#d97706;}
.reg-header{background:linear-gradient(135deg,#0f2942,#1e4976);border-radius:13px;padding:18px 24px;color:#fff;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 18px rgba(15,41,66,.35);}
/* Quota widget */
.quota-widget{background:#fff;border-radius:12px;border:1.5px solid #e2e8f0;padding:14px 16px;box-shadow:0 2px 10px rgba(0,0,0,.05);}
.qw-title{font-weight:800;font-size:13px;color:#0f2942;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.q-row{background:#f8fafc;border-radius:8px;padding:9px 12px;margin-bottom:8px;border:1px solid #e2e8f0;}
.q-row.q-full{background:#fef2f2;border-color:#fca5a5;}
.q-row.q-warn{background:#fffbeb;border-color:#fde68a;}
.q-unit-name{font-weight:700;font-size:12px;color:#1a3a5c;margin-bottom:5px;}
.q-bars{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.q-bar-label{font-size:10px;color:#64748b;display:flex;justify-content:space-between;margin-bottom:2px;}
.q-track{background:#e2e8f0;border-radius:99px;height:6px;overflow:hidden;}
.q-fill{height:100%;border-radius:99px;transition:width .4s;}
.qf-green{background:#059669;} .qf-orange{background:#d97706;} .qf-red{background:#dc2626;}
.full-tag{background:#fee2e2;color:#991b1b;font-size:10px;font-weight:700;padding:1px 7px;border-radius:20px;}
.ok-tag{background:#dcfce7;color:#166534;font-size:10px;font-weight:700;padding:1px 7px;border-radius:20px;}
/* Registration form */
.reg-form{background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:20px 24px;box-shadow:0 1px 8px rgba(0,0,0,.05);}
.search-bar{display:flex;gap:10px;align-items:center;background:#f0f9ff;border:1.5px solid #bae6fd;border-radius:10px;padding:12px 16px;margin-bottom:16px;}
.result-zone{background:#f8fafc;border-radius:10px;border:1px solid #e2e8f0;padding:16px;min-height:80px;direction:rtl;}
/* Inline quota alert in form */
.inline-quota{border-radius:8px;padding:10px 14px;font-size:12px;margin-top:8px;display:none;}
.iq-ok{background:#dcfce7;border:1px solid #86efac;color:#166534;}
.iq-warn{background:#fef9c3;border:1px solid #fde047;color:#854d0e;}
.iq-full{background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;}
</style>

<!-- HEADER -->
<div class="reg-header">
  <div>
    <h4 style="margin:0;font-size:18px;font-weight:800">📋 تسجيل حاج جديد</h4>
    <div style="font-size:12px;opacity:.75;margin-top:3px">تسجيل الحجاج من نظام الموارد البشرية أو يدوياً</div>
  </div>
  <div style="display:flex;gap:8px">
    <a href="@Url.Action("Index","Units")" class="btn btn-sm" style="background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3)">
      <i class="fa fa-sliders"></i> إدارة الأعداد المسموحة
    </a>
    <a href="@Url.Action("Index","AlhajjMasters")" class="btn btn-sm btn-light">
      <i class="fa fa-list"></i> القائمة الكاملة
    </a>
  </div>
</div>

<div class="row" style="direction:rtl">

  <!-- LEFT: QUOTA WIDGET ──────────────────────────────────── -->
  <div class="col-md-4">
    <div class="quota-widget">
      <div class="qw-title">
        📊 الحصص المتبقية
        <button class="btn btn-xs btn-link p-0" onclick="refreshQuota()" title="تحديث" style="font-size:11px;color:#94a3b8">
          <i class="fa fa-refresh"></i>
        </button>
      </div>
      <div id="quotaContent">
        <div style="text-align:center;padding:20px;color:#94a3b8;font-size:12px">
          <i class="fa fa-spinner fa-spin"></i> جاري التحميل...
        </div>
      </div>
      <div style="font-size:10px;color:#94a3b8;margin-top:8px;text-align:left">
        آخر تحديث: <span id="quotaTime">—</span>
      </div>
    </div>

    <!-- Inline quota alert when unit selected in form -->
    <div class="inline-quota iq-ok mt-2" id="inlineQuota"></div>
  </div>

  <!-- RIGHT: REGISTRATION FORM ────────────────────────────── -->
  <div class="col-md-8">
    <div class="reg-form">

      <!-- SEARCH BAR -->
      <div class="search-bar">
        <div style="font-weight:700;font-size:13px;color:#1a3a5c;white-space:nowrap">🔍 البحث في HRMS:</div>
        <input type="text" id="getServiceNumber" class="form-control form-control-sm"
          style="direction:rtl;max-width:200px" placeholder="الرقم العسكري"
          onkeydown="if(event.key==='Enter'){GetEmployee();}">
        <button onclick="GetEmployee()" class="btn btn-primary btn-sm">
          <i class="fa fa-search"></i> بحث
        </button>
        <div id="spinner" style="display:none">
          <i class="fa fa-spinner fa-spin" style="color:#1a3a5c"></i>
        </div>
      </div>

      <!-- RESULT ZONE (populated by AJAX) -->
      <div class="result-zone" id="EmployeeDetailsView">
        <div style="text-align:center;color:#cbd5e1;font-size:13px;padding:20px 0">
          ابحث بالرقم العسكري لجلب بيانات الموظف من HRMS
        </div>
      </div>

    </div>
  </div>
</div>

@section Scripts {
<script>
(function(){
'use strict';

// ── Quota widget ─────────────────────────────────────────────────────────
function pct(used, total){ return total>0 ? Math.round(used/total*100) : 0; }
function fillClass(p){ return p>=100?'qf-red':p>=80?'qf-orange':'qf-green'; }

window.refreshQuota = function(){
  $.getJSON('@Url.Action("GetMyQuota","Units")', function(units){
    if (!units || units.length === 0) {
      $('#quotaContent').html('<div style="text-align:center;color:#94a3b8;font-size:12px;padding:16px">لا توجد وحدات مرتبطة بحسابك</div>');
      return;
    }
    var html = '';
    units.forEach(function(u){
      var rp=pct(u.regularUsed,u.allowNumber), sp=pct(u.standByUsed,u.standBy);
      var isFullR=u.regularFull, isFullS=u.standByFull;
      var rowCls = isFullR?'q-row q-full':isFullS?'q-row q-warn':'q-row';
      html += `
      <div class="${rowCls}" data-unit-id="${u.unitId}">
        <div class="q-unit-name">
          🏛️ <strong>${u.unitNameAr}</strong>
          ${isFullR
            ? '<span class="full-tag">مكتمل</span>'
            : `<span class="ok-tag">تبقى ${(u.regularRemain||0)+(u.standByRemain||0)}</span>`}
        </div>
        <div class="q-bars">
          <div>
            <div class="q-bar-label">
              <span style="color:#1a3a5c;font-weight:700">أصلي</span>
              <span>${u.regularUsed}/${u.allowNumber}</span>
            </div>
            <div class="q-track"><div class="q-fill ${fillClass(rp)}" style="width:${Math.min(rp,100)}%"></div></div>
          </div>
          <div>
            <div class="q-bar-label">
              <span style="color:#d97706;font-weight:700">احتياط</span>
              <span>${u.standByUsed}/${u.standBy}</span>
            </div>
            <div class="q-track"><div class="q-fill ${fillClass(sp)}" style="width:${Math.min(sp,100)}%"></div></div>
          </div>
        </div>
        <div style="margin-top:8px;font-size:10px;color:#94a3b8;display:flex;gap:12px">
          <span>أصلي متبقٍ: <strong style="color:${isFullR?'#dc2626':'#059669'}">${u.regularRemain}</strong></span>
          <span>احتياط متبقٍ: <strong style="color:${isFullS?'#d97706':'#059669'}">${u.standByRemain}</strong></span>
        </div>
      </div>`;
    });
    $('#quotaContent').html(html);
    var now=new Date(); $('#quotaTime').text(now.getHours()+':'+String(now.getMinutes()).padStart(2,'0'));
  }).fail(function(){ $('#quotaContent').html('<div style="color:#dc2626;font-size:12px;text-align:center">تعذر التحميل</div>'); });
};

// ── Called from the form when unit/type changes ──────────────────────────
window.updateInlineQuota = function(unitId, typeCode){
  if(!unitId || !typeCode){ $('#inlineQuota').hide(); return; }
  $.getJSON('@Url.Action("GetQuota","Units")', {unitId:unitId}, function(q){
    var $iq=$('#inlineQuota');
    var isRegular=(+typeCode===1);
    var isStandby=(+typeCode===2);
    if(isRegular){
      if(q.regularFull){
        $iq.attr('class','inline-quota iq-full').html('⛔ الحاج الأصلي ممتلئ ('+q.allowNumber+'/'+q.allowNumber+') — لا يمكن إضافة المزيد').show();
      } else {
        var remain=q.regularRemain;
        var cls=remain<=2?'iq-warn':'iq-ok';
        $iq.attr('class','inline-quota '+cls).html('✅ تبقى <strong>'+remain+'</strong> مقعد أصلي من أصل '+q.allowNumber).show();
      }
    } else if(isStandby){
      if(q.standbyFull){
        $iq.attr('class','inline-quota iq-full').html('⛔ الاحتياط ممتلئ ('+q.standBy+'/'+q.standBy+')').show();
      } else {
        var remain=q.standbyRemain;
        var cls=remain<=1?'iq-warn':'iq-ok';
        $iq.attr('class','inline-quota '+cls).html('✅ تبقى <strong>'+remain+'</strong> مقعد احتياط من أصل '+q.standBy).show();
      }
    } else {
      $iq.hide();
    }
  });
};

// ── HRMS fetch ────────────────────────────────────────────────────────────
window.GetEmployee = function(){
  var sn=$('#getServiceNumber').val().trim();
  if(!sn){ toastr.warning('أدخل الرقم العسكري أولاً'); return; }
  $('#spinner').show(); $('#EmployeeDetailsView').html('');
  $.ajax({
    url: '@Url.Action("GetAlhajjDataFormWebService","AlhajjMasters")',
    type: 'GET',
    dataType: 'html',
    data: { ServiceNumber: sn },
    success: function(data){
      $('#spinner').hide();
      $('#EmployeeDetailsView').html(data);
      toastr.success('تم جلب البيانات بنجاح');
      $('#getServiceNumber').val('');
      // After loading, wire up quota change events in the newly rendered form
      wireQuotaEvents();
    },
    error: function(xhr){
      $('#spinner').hide();
      toastr.error(xhr.responseText || 'لم يتم العثور على الموظف');
    }
  });
};

function wireQuotaEvents(){
  // Wire unit/type selects inside the loaded partial
  $(document).off('change.quota','#UnitId, select[name="UnitId"]')
    .on('change.quota','#UnitId, select[name="UnitId"]', function(){
      var uid=$(this).val(), tc=$('#ParameterId, select[name="ParameterId"]').val();
      updateInlineQuota(uid,tc);
    });
  $(document).off('change.quota2','#ParameterId, select[name="ParameterId"]')
    .on('change.quota2','#ParameterId, select[name="ParameterId"]', function(){
      var uid=$('#UnitId, select[name="UnitId"]').val(), tc=$(this).val();
      updateInlineQuota(uid,tc);
    });
}

$(function(){
  toastr.options={positionClass:'toast-top-left',timeOut:3000,rtl:true};
  refreshQuota();
  setInterval(refreshQuota, 30000);
  wireQuotaEvents();
});

}());
</script>}
